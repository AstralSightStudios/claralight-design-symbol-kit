{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "paths": {
      "@claralight-design/symbol-kit-compiler": ["../../packages/compiler/src/index.ts"],
      "@claralight-design/symbol-kit-core": ["../../packages/core/src/index.ts"]
    },
    "types": ["node", "vite/client"]
  },
  "include": ["src", "vite.config.ts"]
}
