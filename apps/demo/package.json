{
  "name": "@claralight-design/symbol-kit-demo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node ./node_modules/astro/bin/astro.mjs check && node ./node_modules/astro/bin/astro.mjs build",
    "dev": "node ./node_modules/astro/bin/astro.mjs dev --host 127.0.0.1",
    "preview": "node ./node_modules/astro/bin/astro.mjs preview --host 127.0.0.1",
    "lint": "node ../../node_modules/eslint/bin/eslint.js .",
    "test": "node ../../node_modules/vitest/vitest.mjs run"
  },
  "dependencies": {
    "@astrojs/react": "6.0.1",
    "@claralight-design/symbol-kit-compiler": "workspace:*",
    "@claralight-design/symbol-kit-core": "workspace:*",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "astro": "7.0.7",
    "vite": "^7.3.6"
  }
}
