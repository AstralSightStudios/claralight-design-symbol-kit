---
import IconLab from "../components/IconLab";
import "../styles/global.css";
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="Symbol Kit 图标渲染预览" />
    <meta name="theme-color" content="#1972F8" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#1C4D98" media="(prefers-color-scheme: dark)" />
    <title>Symbol Kit Demo</title>
  </head>
  <body>
    <main>
      <header class="hero">
        <p class="eyebrow">CLARALIGHT / SYMBOL KIT</p>
        <h1>Symbol<br /><i>render lab.</i></h1>
        <p class="intro">浏览由 Symbol 数据生成的图标，并实时调整样式、字重与颜色。</p>
      </header>
      <IconLab client:load />
    </main>
  </body>
</html>
