{
  "name": "@claralight-design/symbol-kit-core",
  "version": "0.0.0",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./symbols": {
      "types": "./dist/symbols/index.d.ts",
      "default": "./dist/symbols/index.js"
    },
    "./symbols/*": {
      "types": "./dist/symbols/*.d.ts",
      "default": "./dist/symbols/*.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run",
    "lint": "eslint ."
  }
}
