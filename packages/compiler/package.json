{
  "name": "@claralight-design/symbol-kit-compiler",
  "version": "0.1.1",
  "description": "SVG parsing, semantic classification, geometry processing, and symbol generation for ClaraLight Design.",
  "type": "module",
  "sideEffects": false,
  "license": "MIT",
  "author": "AstralSight Studios",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AstralSightStudios/claralight-design-symbol-kit.git",
    "directory": "packages/compiler"
  },
  "homepage": "https://github.com/AstralSightStudios/claralight-design-symbol-kit#readme",
  "bugs": {
    "url": "https://github.com/AstralSightStudios/claralight-design-symbol-kit/issues"
  },
  "keywords": [
    "icons",
    "svg",
    "compiler",
    "design-system",
    "symbol"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run",
    "lint": "eslint .",
    "prepack": "node -e \"const fs = require('node:fs'); fs.rmSync('dist', { recursive: true, force: true }); fs.rmSync('.tsbuildinfo', { force: true })\" && node ../../node_modules/typescript/bin/tsc -b tsconfig.publish.json --force"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@claralight-design/symbol-kit-core": "workspace:*",
    "paper": "^0.12.18",
    "paperjs-offset": "^2.1.2"
  }
}
