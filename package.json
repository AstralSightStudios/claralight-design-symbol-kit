{
  "name": "@claralight-design/symbol-kit",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "node ./node_modules/typescript/bin/tsc -b",
    "test": "node ./node_modules/vitest/vitest.mjs run",
    "lint": "node ./node_modules/eslint/bin/eslint.js packages --ext .ts,.tsx",
    "format": "node ./node_modules/prettier/bin/prettier.cjs --write .",
    "check": "pnpm lint && pnpm test && pnpm build"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@types/node": "^22.15.34",
    "eslint": "^9.31.0",
    "prettier": "^3.6.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.37.0",
    "vitest": "^3.2.4"
  }
}
